<Window x:Class="leishen.ReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏已退出" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowState="Maximized" Loaded="Window_Loaded">
    <Window.Resources>
        <Storyboard x:Key="ReminderPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="0.6"><EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction></EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="1"><EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction></EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="ScaleInButton">
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#CC0000">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtReminderTitle" Text="⚠️ 游戏已退出 ⚠️" FontSize="72" FontWeight="ExtraBold" Foreground="Yellow" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtReminderSub" Text="PUBG 已经关闭！" FontSize="44" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,10"/>
                <TextBlock x:Name="TxtReminderDetail" Text="已自动暂停雷神加速器" FontSize="28" Foreground="#FF8888" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                <Border Background="#AA0000" CornerRadius="15" Padding="20,15" Margin="0,20,0,30">
                    <StackPanel>
                        <TextBlock x:Name="TxtPauseTime" Text="暂停时间：刚刚" FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtTodayStats" Text="今日暂停：0 次" FontSize="18" Foreground="#FFCCCC" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Button x:Name="BtnConfirm" Content="✓ 知道了" Click="Close_Click" Width="220" Height="70"
                        Background="#FFDD44" Foreground="#CC0000" FontWeight="Bold" FontSize="24" BorderThickness="0"
                        Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform><ScaleTransform/></Button.RenderTransform>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="35">
                                            <Border.Effect><DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="4" Color="#000000"/></Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bg" Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
