<Window x:Class="leishen.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="坐标捕获" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowState="Maximized" Cursor="Cross"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Storyboard x:Key="CapturePulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="0.8" Duration="0:0:0.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border Background="#80000000">
        <Grid>
            <!-- 中心准星 -->
            <Ellipse Width="60" Height="60" Stroke="#00E5FF" StrokeThickness="2" Opacity="0.6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Ellipse Width="6" Height="6" Fill="#00E5FF" Opacity="0.8" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#16213E" CornerRadius="16" Padding="24,20" Opacity="0.95"
                        BorderBrush="#00E5FF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🎯 坐标捕获模式" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="点击雷神加速器的「暂停」按钮" FontSize="16" Foreground="#00E5FF" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <Rectangle Height="1" Fill="#2A2A4A" Margin="10,15,10,10"/>
                        <TextBlock Text="按 ESC 取消 · 点击后自动获取坐标" FontSize="12" Foreground="#667788" HorizontalAlignment="Center"/>
                        <TextBlock Text="仅支持捕获 雷神加速器 窗口内的点击" FontSize="11" Foreground="#555" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 顶部提示 -->
            <Border Background="#00E5FF" Height="4" VerticalAlignment="Top" Opacity="0.5"/>
        </Grid>
    </Border>
</Window>
